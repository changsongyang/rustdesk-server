# RustDesk Pro Server Configuration

# Database Configuration
DATABASE_URL=sqlite:./data/rustdesk_pro.db
PRO_DB_URL=./data/rustdesk_pro.db

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=rustdesk-pro-jwt-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# Log Configuration
LOG_LEVEL=info
LOG_FILE=./logs/rustdesk-pro.log

# License Configuration
LICENSE_PRIVATE_KEY_FILE=./keys/license_private_key
LICENSE_PUBLIC_KEY_FILE=./keys/license_public_key

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@rustdesk.local
